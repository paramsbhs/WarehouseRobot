<?xml version="1.0"?>
<sdf version="1.6">
<world name="warehouse">
  <light name="sun" type="directional">
    <cast_shadows>true</cast_shadows>
    <pose>0 0 10 0 0 0</pose>
    <diffuse>0.8 0.8 0.8 1</diffuse>
    <specular>0.2 0.2 0.2 1</specular>
    <direction>-0.5 0.1 -0.9</direction>
  </light>
  <model name="ground_plane">
    <static>true</static>
    <link name="link">
      <collision name="collision">
        <geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry>
        <surface><friction><ode><mu>100</mu><mu2>50</mu2></ode></friction></surface>
      </collision>
      <visual name="visual">
        <geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry>
      </visual>
    </link>
  </model>

  <plugin name="GazeboPlugin" filename="lib/libGazeboCoSimPlugin.so">
    <portNumber>14581</portNumber>
  </plugin>

  <gui fullscreen="0">
    <camera name="user_camera">
      <pose>25 -20 40 0 0.85 1.5708</pose>
    </camera>
  </gui>

  <model name="wall_n">
    <static>true</static>
    <pose>25 30 1 0 0 0</pose>
    <link name="link">
      <collision name="collision">
        <geometry><box><size>50 0.2 2</size></box></geometry>
      </collision>
      <visual name="visual">
        <geometry><box><size>50 0.2 2</size></box></geometry>
      </visual>
    </link>
  </model>

  <model name="wall_s">
    <static>true</static>
    <pose>25 0 1 0 0 0</pose>
    <link name="link">
      <collision name="collision">
        <geometry><box><size>50 0.2 2</size></box></geometry>
      </collision>
      <visual name="visual">
        <geometry><box><size>50 0.2 2</size></box></geometry>
      </visual>
    </link>
  </model>

  <model name="wall_w">
    <static>true</static>
    <pose>0 15 1 0 0 0</pose>
    <link name="link">
      <collision name="collision">
        <geometry><box><size>0.2 30 2</size></box></geometry>
      </collision>
      <visual name="visual">
        <geometry><box><size>0.2 30 2</size></box></geometry>
      </visual>
    </link>
  </model>

  <model name="wall_e">
    <static>true</static>
    <pose>50 15 1 0 0 0</pose>
    <link name="link">
      <collision name="collision">
        <geometry><box><size>0.2 30 2</size></box></geometry>
      </collision>
      <visual name="visual">
        <geometry><box><size>0.2 30 2</size></box></geometry>
      </visual>
    </link>
  </model>

  <model name="rack_1">
    <static>true</static>
    <pose>26 8 1 0 0 0</pose>
    <link name="link">
      <collision name="collision">
        <geometry><box><size>32 2 2</size></box></geometry>
      </collision>
      <visual name="visual">
        <geometry><box><size>32 2 2</size></box></geometry>
      </visual>
    </link>
  </model>

  <model name="rack_2">
    <static>true</static>
    <pose>26 15 1 0 0 0</pose>
    <link name="link">
      <collision name="collision">
        <geometry><box><size>32 2 2</size></box></geometry>
      </collision>
      <visual name="visual">
        <geometry><box><size>32 2 2</size></box></geometry>
      </visual>
    </link>
  </model>

  <model name="rack_3">
    <static>true</static>
    <pose>26 22 1 0 0 0</pose>
    <link name="link">
      <collision name="collision">
        <geometry><box><size>32 2 2</size></box></geometry>
      </collision>
      <visual name="visual">
        <geometry><box><size>32 2 2</size></box></geometry>
      </visual>
    </link>
  </model>

  <model name="warehouse_robot">
    <pose>4 4 0 0 0 0</pose>
    <link name="chassis">
      <pose>0 0 0.1 0 0 0</pose>
      <inertial>
        <mass>10</mass>
        <inertia><ixx>0.1</ixx><iyy>0.15</iyy><izz>0.2</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <collision name="collision">
        <geometry><box><size>0.4 0.3 0.1</size></box></geometry>
      </collision>
      <visual name="visual">
        <geometry><box><size>0.4 0.3 0.1</size></box></geometry>
        <material><ambient>1 0.45 0 1</ambient><diffuse>1 0.45 0 1</diffuse></material>
      </visual>
      <visual name="beacon">
        <pose>0 0 0.85 0 0 0</pose>
        <geometry><box><size>0.25 0.25 1.6</size></box></geometry>
        <material><ambient>1 0.45 0 1</ambient><diffuse>1 0.45 0 1</diffuse></material>
      </visual>
      <collision name="caster">
        <pose>-0.15 0 -0.05 0 0 0</pose>
        <geometry><sphere><radius>0.05</radius></sphere></geometry>
        <surface><friction><ode><mu>0</mu><mu2>0</mu2></ode></friction></surface>
      </collision>
      <visual name="caster_visual">
        <pose>-0.15 0 -0.05 0 0 0</pose>
        <geometry><sphere><radius>0.05</radius></sphere></geometry>
      </visual>
    </link>
    <link name="left_wheel">
      <pose>0.1 0.17 0.1 -1.5707 0 0</pose>
      <inertial>
        <mass>1</mass>
        <inertia><ixx>0.003</ixx><iyy>0.003</iyy><izz>0.005</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <collision name="collision">
        <geometry><cylinder><radius>0.1</radius><length>0.05</length></cylinder></geometry>
      </collision>
      <visual name="visual">
        <geometry><cylinder><radius>0.1</radius><length>0.05</length></cylinder></geometry>
      </visual>
    </link>
    <link name="right_wheel">
      <pose>0.1 -0.17 0.1 -1.5707 0 0</pose>
      <inertial>
        <mass>1</mass>
        <inertia><ixx>0.003</ixx><iyy>0.003</iyy><izz>0.005</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <collision name="collision">
        <geometry><cylinder><radius>0.1</radius><length>0.05</length></cylinder></geometry>
      </collision>
      <visual name="visual">
        <geometry><cylinder><radius>0.1</radius><length>0.05</length></cylinder></geometry>
      </visual>
    </link>
    <joint type="revolute" name="left_wheel_joint">
      <child>left_wheel</child>
      <parent>chassis</parent>
      <axis><xyz>0 0 1</xyz></axis>
    </joint>
    <joint type="revolute" name="right_wheel_joint">
      <child>right_wheel</child>
      <parent>chassis</parent>
      <axis><xyz>0 0 1</xyz></axis>
    </joint>
    <link name="lidar">
      <pose>0.15 0 0.2 0 0 0</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia><ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0001</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="visual">
        <geometry><cylinder><radius>0.03</radius><length>0.04</length></cylinder></geometry>
      </visual>
      <sensor name="lidar" type="ray">
        <always_on>true</always_on>
        <update_rate>10</update_rate>
        <ray>
          <scan><horizontal>
            <samples>640</samples>
            <resolution>1</resolution>
            <min_angle>-2.356</min_angle>
            <max_angle>2.356</max_angle>
          </horizontal></scan>
          <range><min>0.12</min><max>8</max></range>
        </ray>
      </sensor>
    </link>
    <joint type="fixed" name="lidar_joint">
      <child>lidar</child>
      <parent>chassis</parent>
    </joint>
  </model>
</world>
</sdf>
